# Capy → Go HTTP handlers WITH MATCHING TESTS.
#
# Every `handler X method M path P returns R` declaration generates:
#   1. A handler stub in internal/handlers/handlers.go
#   2. A registered route on the router (same file).
#   3. A matching test in internal/handlers/handlers_test.go.
#
# The team's directory layout and the "every handler must have a
# test" rule are baked into the library — new contributors can't
# accidentally drop a handler in the wrong place OR forget to
# write a test.
extension go

comments
    line "#"
end

context
    handlers []
end

# A single flat declaration. The `accepts` arg is optional — pattern
# without it has higher priority so it wins when present, otherwise
# falls back to the simpler form.
function handler_with_accepts
    priority 100
    arg literal "handler"
    arg capture name ident
    arg literal "method"
    arg capture method ident
    arg literal "path"
    arg capture path string
    arg literal "accepts"
    arg capture accepts string
    arg literal "returns"
    arg capture returns string
    append context.handlers {name: name, method: method, path: path, accepts: accepts, returns: returns}
end

function handler_no_accepts
    arg literal "handler"
    arg capture name ident
    arg literal "method"
    arg capture method ident
    arg literal "path"
    arg capture path string
    arg literal "returns"
    arg capture returns string
    append context.handlers {name: name, method: method, path: path, accepts: "", returns: returns}
end

# Output file #1: handlers + router in one .go file.
file "internal/handlers/handlers.go"
    write `// Generated by Capy. Edit script.capy and re-run to regenerate.
package handlers

import (
    "net/http"
)

// Mount registers every declared handler on the given mux.
func Mount(mux *http.ServeMux) {
`
    for h in context.handlers
        write `    mux.HandleFunc("${h.method} ${unquote h.path}", ${h.name})
`
    end
    write `}
`
    for h in context.handlers
        write `
// ${h.method} ${unquote h.path}`
        if h.accepts
            write ` — accepts ${unquote h.accepts}`
        end
        write ` — returns ${unquote h.returns}
func ${h.name}(w http.ResponseWriter, r *http.Request) {
    // TODO: implement ${h.name}
    http.Error(w, "${h.name} not implemented", http.StatusNotImplemented)
}
`
    end
    write `
`
end

# Output file #2: matching tests. One Test_<Name>_RouteRegistered per handler.
file "internal/handlers/handlers_test.go"
    write `// Generated by Capy. Smoke tests verifying every declared route
// is reachable. Replace these with real assertions as you
// implement each handler.
package handlers

import (
    "net/http"
    "net/http/httptest"
    "testing"
)
`
    for h in context.handlers
        write `
func Test_${h.name}_RouteRegistered(t *testing.T) {
    mux := http.NewServeMux()
    Mount(mux)
    req := httptest.NewRequest("${h.method}", "${unquote h.path}", nil)
    rr := httptest.NewRecorder()
    mux.ServeHTTP(rr, req)
    // Until the handler body is filled in, this returns 501.
    if rr.Code != http.StatusNotImplemented {
        t.Errorf("expected 501, got %d", rr.Code)
    }
}
`
    end
    write `
`
end

file "README.md"
    write `# Handlers package

Generated by Capy from \`script.capy\`. ${len context.handlers}
handler`
    if (len context.handlers) != 1
        write `s`
    end
    write ` declared:
`
    for h in context.handlers
        write `
- \`${h.method} ${unquote h.path}\` → \`${h.name}\` returns \`${unquote h.returns}\``
        if h.accepts
            write ` (accepts \`${unquote h.accepts}\`)`
        end
    end
    write `

## How to add a handler

1. Add a \`handler ... method ... path ... returns ...\` line to
   \`script.capy\` (one line).
2. Run \`capy run --out-dir . lib.capy script.capy\`. The handler
   stub appears in \`internal/handlers/handlers.go\`, the test in
   \`handlers_test.go\`, and this README updates.
3. Implement the handler body. The smoke test will start failing
   (because the response is no longer 501); replace it with a
   real assertion of your contract.

The directory layout is fixed by the library: never argue about
where handlers live again.
`
end
