# Capy → TypeScript HTTP client (same DSL as lib_openapi.capy).
extension ts

comments
    line "#"
end

context
    title ""
    endpoints []
end

function api
    arg literal "api"
    arg capture title string
    arg literal "version"
    arg capture ver string
    set context.title title
end

function endpoint
    arg literal "endpoint"
    arg capture method ident
    arg capture path string
    block_closer end
    write `
// ${method} ${path}
export async function ${method}_handler(path: string): Promise<unknown> {
  const res = await fetch(path, { method: "${method}" });
  return res.json();
}
`
end

function summary
    arg literal "summary"
    arg capture text string
    write `// ${text}
`
end

function param
    arg literal "param"
    arg capture loc ident
    arg capture name ident
    arg capture typ ident
    write `// @param ${loc} ${name}: ${typ}
`
end

function param_body
    priority 100
    arg literal "param"
    arg literal "body"
    arg capture schema string
    write `// @param body ${schema}
`
end

function returns
    arg literal "returns"
    arg capture schema string
    write `// @returns ${schema}
`
end

function end
end

file_template
    write `// ──────────────────────────────────────────────────────────
// ${context.title} — generated TypeScript client.
// Source: script.capy
// ──────────────────────────────────────────────────────────
${body}
`
end
