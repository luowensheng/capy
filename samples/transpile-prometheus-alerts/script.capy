group capy_alerts

alert HighErrorRate
    expr     "rate(http_requests_total{status=~'5..'}[5m]) > 0.05"
    for      "10m"
    severity "page"
    summary  "5xx error rate > 5% for 10 minutes"
end

alert SlowResponse
    expr     "histogram_quantile(0.95, http_request_duration_seconds) > 2"
    for      "5m"
    severity "warning"
    summary  "p95 latency > 2s"
end
