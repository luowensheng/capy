# Same source, target 2: JSON document.
extension json

comments
    line "#"
end

context
    users []
end

function user
    arg capture name ident
    arg capture age int
    arg capture status ident
    append context.users {name: name, age: age, status: status}
end

file_template
    write `{ "users": ${toJSONIndent context.users} }
`
end
