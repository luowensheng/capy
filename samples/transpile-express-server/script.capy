# A mock REST API in 6 declarative lines. Every handler is an
# ABSTRACT verb — never inline JavaScript — so the same source
# survives if you swap the library to Flask, Rails, Gin, etc.

port 8080
use logging

endpoint get  "/health"      health_check
endpoint get  "/users"       list_mock_users
endpoint post "/users"       create_user
endpoint get  "/users/:id"   get_user_by_id
