# LEVEL 3 — full control. Same library + same `landing / hero / feature
# / cta` primitives, PLUS escape hatches (`raw_head`, `style_override`,
# `raw_section`, `raw_footer`) for whatever the abstraction doesn't cover.
#
# You're never stuck: anything you'd write in raw HTML/CSS you can drop
# in here. The library handles the boring parts; you take over the
# interesting ones.

landing "Capy — Pro"

    # Drop literal HTML into <head> when the library's defaults aren't enough.
    raw_head "<meta name=\"theme-color\" content=\"#4f46e5\">"

    # Override / extend the library's stylesheet. (Strings stay on one
    # line; use \n if you want to keep your CSS readable.)
    style_override "body { background: linear-gradient(160deg, #0a0e1f, #1a1230); } .hero h1 { background: linear-gradient(90deg, #c4b5fd, #67e8f9); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-size: 56px; } .feature { transition: transform 0.15s; } .feature:hover { transform: translateY(-4px); border-color: rgba(167,139,250,0.4); } .badge { display: inline-block; background: rgba(167,139,250,0.16); color: #c4b5fd; padding: 4px 12px; border-radius: 999px; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 14px; }"

    hero "Capy — Pro" "Same engine. Same grammar. Take exactly the control you need."

    feature "Zero default grammar"  "Every keyword is defined by the library. 0 reserved words."
    feature "55+ samples"           "Recipes, invoices, Android apps, libtorch trainers — all from .capy sources."
    feature "Browser playground"    "The compiler runs as WebAssembly. Edit + preview + download."
    feature "MCP server included"   "Plug into Claude Desktop, Cursor, Zed with one config entry."
    feature "Metaprogramming"       "Source declares its own DSL primitives inline via `define ... end`."
    feature "Multi-file output"     "One source → web app + Android + iOS + libtorch C++ trainer."

    # A whole custom section the library doesn't model — write raw HTML.
    raw_section "<section style='background:rgba(167,139,250,0.06);border-radius:14px;padding:28px 32px;margin:36px 0;text-align:center;border:1px solid rgba(167,139,250,0.18);'><span class='badge'>Numbers that matter</span><div style='display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:12px;'><div><div style='font-size:30px;font-weight:700;color:#c4b5fd;'>55+</div><div style='font-size:12px;color:#94a3b8;'>curated samples</div></div><div><div style='font-size:30px;font-weight:700;color:#c4b5fd;'>6.2MB</div><div style='font-size:12px;color:#94a3b8;'>wasm bundle</div></div><div><div style='font-size:30px;font-weight:700;color:#c4b5fd;'>0</div><div style='font-size:12px;color:#94a3b8;'>built-in keywords</div></div><div><div style='font-size:30px;font-weight:700;color:#c4b5fd;'>MIT</div><div style='font-size:12px;color:#94a3b8;'>license</div></div></div></section>"

    cta "Open the playground" "https://luowensheng.github.io/capy/playground/"

    # Replace the library's default footer entirely.
    raw_footer "<span style='color:#94a3b8'>Open source under MIT · </span><a href='https://github.com/luowensheng/capy' style='color:#c4b5fd'>github.com/luowensheng/capy</a>"
end
